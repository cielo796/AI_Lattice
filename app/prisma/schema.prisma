generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TenantStatus {
  active
  inactive
}

enum UserStatus {
  active
  inactive
}

enum AppStatus {
  draft
  published
  archived
}

enum WorkflowTriggerType {
  create
  update
  schedule
  webhook
  status_change
}

enum WorkflowStatus {
  draft
  active
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum FieldType {
  text
  textarea
  number
  date
  datetime
  boolean
  select
  user_ref
  master_ref
  file
  ai_generated
  calculated
}

model Tenant {
  id        String       @id @default(cuid())
  name      String
  code      String       @unique
  status    TenantStatus @default(active)
  planType  String       @map("plan_type")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  users     User[]
  apps      App[]
  auditLogs AuditLog[]
  workflows Workflow[]
  approvals Approval[]
  openAISettings TenantOpenAISettings?

  @@map("tenants")
}

model TenantOpenAISettings {
  id              String   @id @default(cuid())
  tenantId        String   @unique @map("tenant_id")
  apiKeyEncrypted String   @map("api_key_encrypted")
  apiKeyLastFour  String   @map("api_key_last_four")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_openai_settings")
}

model User {
  id           String     @id @default(cuid())
  tenantId     String     @map("tenant_id")
  email        String
  name         String
  avatarUrl    String?    @map("avatar_url")
  status       UserStatus @default(active)
  passwordHash String?    @map("password_hash")
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  tenant              Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions            Session[]
  createdApps         App[]           @relation("AppCreatedBy")
  createdRecords      AppRecord[]     @relation("AppRecordCreatedBy")
  updatedRecords      AppRecord[]     @relation("AppRecordUpdatedBy")
  recordComments      RecordComment[] @relation("RecordCommentCreatedBy")
  uploadedAttachments Attachment[]    @relation("AttachmentUploadedBy")
  createdWorkflows    Workflow[]      @relation("WorkflowCreatedBy")
  requestedApprovals  Approval[]      @relation("ApprovalRequestedBy")
  assignedApprovals   Approval[]      @relation("ApprovalApprover")
  actedApprovals      Approval[]      @relation("ApprovalActedBy")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@index([expiresAt])
  @@map("sessions")
}

model App {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  name        String
  code        String
  description String?
  status      AppStatus @default(draft)
  icon        String    @default("apps")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User        @relation("AppCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  tables    AppTable[]
  fields    AppField[]
  records   AppRecord[]
  workflows Workflow[]
  approvals Approval[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([createdById])
  @@map("apps")
}

model AppTable {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  appId     String   @map("app_id")
  name      String
  code      String
  isSystem  Boolean  @default(false) @map("is_system")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  app       App         @relation(fields: [appId], references: [id], onDelete: Cascade)
  fields    AppField[]
  records   AppRecord[]
  approvals Approval[]

  @@unique([appId, code])
  @@index([tenantId])
  @@index([appId, sortOrder])
  @@map("app_tables")
}

model AppField {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  appId        String    @map("app_id")
  tableId      String    @map("table_id")
  name         String
  code         String
  fieldType    FieldType @map("field_type")
  required     Boolean   @default(false)
  uniqueFlag   Boolean   @default(false) @map("unique_flag")
  defaultValue Json?     @map("default_value")
  settingsJson Json?     @map("settings_json")
  sortOrder    Int       @default(0) @map("sort_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  app   App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  table AppTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([tableId, code])
  @@index([tenantId])
  @@index([appId])
  @@index([tableId, sortOrder])
  @@map("app_fields")
}

model AppRecord {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  appId       String    @map("app_id")
  tableId     String    @map("table_id")
  status      String    @default("active")
  dataJson    Json      @map("data_json")
  createdById String    @map("created_by_id")
  updatedById String    @map("updated_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  app         App             @relation(fields: [appId], references: [id], onDelete: Cascade)
  table       AppTable        @relation(fields: [tableId], references: [id], onDelete: Cascade)
  createdBy   User            @relation("AppRecordCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy   User            @relation("AppRecordUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  comments    RecordComment[]
  attachments Attachment[]
  approvals   Approval[]

  @@index([tenantId])
  @@index([appId, tableId, updatedAt])
  @@index([tableId, deletedAt])
  @@index([createdById])
  @@index([updatedById])
  @@map("app_records")
}

model RecordComment {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  recordId    String   @map("record_id")
  commentText String   @map("comment_text")
  createdById String   @map("created_by_id")
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")

  record    AppRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  createdBy User      @relation("RecordCommentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([recordId, createdAt])
  @@index([createdById])
  @@map("record_comments")
}

model Attachment {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  recordId     String   @map("record_id")
  fileName     String   @map("file_name")
  storagePath  String   @map("storage_path")
  mimeType     String   @map("mime_type")
  fileSize     Int      @map("file_size")
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  record     AppRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  uploadedBy User      @relation("AttachmentUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([recordId, createdAt])
  @@index([uploadedById])
  @@map("attachments")
}

model Workflow {
  id             String              @id @default(cuid())
  tenantId       String              @map("tenant_id")
  appId          String              @map("app_id")
  name           String
  triggerType    WorkflowTriggerType @map("trigger_type")
  status         WorkflowStatus      @default(draft)
  definitionJson Json                @map("definition_json")
  createdById    String              @map("created_by_id")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  app       App        @relation(fields: [appId], references: [id], onDelete: Cascade)
  createdBy User       @relation("WorkflowCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  approvals Approval[]

  @@index([tenantId])
  @@index([appId, status])
  @@index([createdById])
  @@map("workflows")
}

model Approval {
  id            String         @id @default(cuid())
  tenantId      String         @map("tenant_id")
  appId         String         @map("app_id")
  tableId       String         @map("table_id")
  recordId      String         @map("record_id")
  workflowId    String?        @map("workflow_id")
  approverId    String         @map("approver_id")
  requestedById String         @map("requested_by_id")
  actedById     String?        @map("acted_by_id")
  status        ApprovalStatus @default(pending)
  title         String
  description   String?
  commentText   String?        @map("comment_text")
  actedAt       DateTime?      @map("acted_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  app         App       @relation(fields: [appId], references: [id], onDelete: Cascade)
  table       AppTable  @relation(fields: [tableId], references: [id], onDelete: Cascade)
  record      AppRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  workflow    Workflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  approver    User      @relation("ApprovalApprover", fields: [approverId], references: [id], onDelete: Restrict)
  requestedBy User      @relation("ApprovalRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  actedBy     User?     @relation("ApprovalActedBy", fields: [actedById], references: [id], onDelete: Restrict)

  @@index([tenantId, status, createdAt])
  @@index([appId, status])
  @@index([recordId, status])
  @@index([workflowId])
  @@index([approverId, status])
  @@index([requestedById])
  @@map("approvals")
}

model AuditLog {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  actorId       String   @map("actor_id")
  actorName     String   @map("actor_name")
  actionType    String   @map("action_type")
  resourceType  String   @map("resource_type")
  resourceId    String?  @map("resource_id")
  resourceName  String?  @map("resource_name")
  detailJson    Json?    @map("detail_json")
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  result        String   @default("success")
  aiInvolvement String   @default("none") @map("ai_involvement")
  createdAt     DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, actionType, createdAt])
  @@index([tenantId, resourceType, resourceId])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}
